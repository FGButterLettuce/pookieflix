# Public base URL (used in room share links)
# Set this to your Cloudflare Tunnel URL when exposing publicly
APP_BASE_URL=http://localhost:3000

# Server port (host-side when using docker-compose)
PORT=3000

# Maximum upload size in bytes (default 10 GB)
MAX_UPLOAD_BYTES=10737418240

# Room expiry in hours (default 24)
ROOM_TTL_HOURS=24

# Direct upload URL — bypasses Cloudflare's 100MB body limit.
# Set to your LAN address so large files upload directly to the server.
# Leave empty to upload through APP_BASE_URL (fine for small files / no Cloudflare).
# UPLOAD_URL=http://192.168.0.91:3000

# Auth — normally set via the setup wizard or Settings → Change Password.
# Only needed if seeding the password manually (e.g. scripted deploys).
# Generate with: node -e "const c=require('crypto'); const {hashPassword}=require('./server/dist/auth'); console.log(hashPassword('yourpassword'))"
# PASSWORD_HASH=<scrypt output>
# SESSION_SECRET must be set alongside PASSWORD_HASH. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# SESSION_SECRET=<64-char hex>
